// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Categorias {
  id  Int  @id @default(autoincrement())
  nome String
  produtos Produtos[]
}

model Produtos {
  id  Int  @id @default(autoincrement())
  image String?
  nome String
  preco Float
  descricao String
  categoria Categorias? @relation(fields: [categoriaId], references: [id])
  categoriaId Int
}
